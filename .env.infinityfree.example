# InfinityFree production environment
# Rename this file to `.env` on the server only.

APP_ENV=production
APP_URL=your-infinityfree-domain.ct.ws
APP_TIMEZONE=Africa/Nairobi

# Use the exact database values from the InfinityFree control panel.
DB_DRIVER=mysql
DB_HOST=your-infinityfree-db-host
DB_PORT=3306
DB_NAME=your_infinityfree_database
DB_USER=your_infinityfree_db_user
DB_PASS=your_infinityfree_db_password

# Keep this aligned with InfinityFree's upload limits.
MAX_FILE_SIZE_MB=20
